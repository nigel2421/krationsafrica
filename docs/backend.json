
{
  "entities": {
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a single shoe product available for sale in the store.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "onOffer": { "type": "boolean", "description": "Whether the product is currently on promotion." },
        "offerPrice": { "type": "number", "description": "The discounted price if the product is on offer." },
        "category": { "type": "string" },
        "gender": { "type": "string", "enum": ["Men", "Women", "Unisex", "Kids"] },
        "availableSizes": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string", "format": "uri" },
        "stockStatus": { "type": "string", "enum": ["In Stock", "Few Left", "Out of Stock"] },
        "description": { "type": "string" },
        "materials": { "type": "string" },
        "slug": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "brand", "price", "category", "gender", "imageUrl", "stockStatus", "description", "slug", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" }
      },
      "required": ["id", "name", "slug"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email" },
        "customerPhoneNumber": { "type": "string" },
        "deliveryLocation": { "type": "string" },
        "items": { "type": "array", "items": { "type": "string" } },
        "totalAmount": { "type": "number" },
        "orderStatus": { "type": "string", "enum": ["Pending", "Processing", "Shipped", "Delivered", "Cancelled"] },
        "orderedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "customerName", "customerPhoneNumber", "deliveryLocation", "items", "totalAmount", "orderStatus", "orderedAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] }
      },
      "required": ["id", "email", "role"]
    },
    "NewsletterSubscription": {
      "title": "NewsletterSubscription",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "source": { "type": "string", "enum": ["direct", "checkout"] },
        "subscribedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "subscribedAt"]
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "structure": [
      { "path": "/products/{productId}", "definition": { "entityName": "Product" } },
      { "path": "/categories/{categoryId}", "definition": { "entityName": "Category" } },
      { "path": "/orders/{orderId}", "definition": { "entityName": "Order" } },
      { "path": "/userProfiles/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/userProfiles/{userId}/orders/{orderId}", "definition": { "entityName": "Order" } },
      { "path": "/newsletterSubscriptions/{email}", "definition": { "entityName": "NewsletterSubscription" } }
    ]
  }
}
