rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // List of authorized admin emails and UIDs
      let adminEmails = [
        'nigel2421@gmail.com', 
        'nigelandahua@outlook.com', 
        'vk101mwanzia@gmail.com'
      ];
      let adminUids = [
        'TMsYLdQiIENfcUnviF8Jpe0WUS93', 
        'MHlWC7fUH2RkmDpBBAKt0vMYA4W2',
        'G0QIvRx7N7TSfYk9bIB1wWwkO6E3'
      ];
      
      // Check if user is in static lists
      let isStaticAdmin = isSignedIn() && (
        (request.auth.token.email in adminEmails) || 
        (request.auth.uid in adminUids)
      );

      // Check if user has admin role in their profile
      let isDatabaseAdmin = isSignedIn() && 
        exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == 'admin';

      return isStaticAdmin || isDatabaseAdmin;
    }

    // --- COLLECTION RULES ---

    // Products and Categories: Globally readable for storefront
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Newsletter: Public can subscribe (create), only admins can manage the list
    match /newsletterSubscriptions/{email} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    // Orders: Public can create (checkout), only admins manage fulfillment
    match /orders/{orderId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    // Media: Publicly readable assets for the catalog, restricted writes
    match /media/{mediaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Profiles: Private access
    match /userProfiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Orders sub-collection for account history
      match /orders/{orderId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow write: if isAdmin();
      }
    }
  }
}
// Forced Rule Synchronization Sequence: 2026-03-10T14:00:00Z